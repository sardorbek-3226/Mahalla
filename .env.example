# Backend REST API base URL (TZ: /api/v1 prefiksi)
VITE_API_URL=http://localhost:5000/api/v1

# Socket.IO server URL (real-time chat, notifications)
VITE_SOCKET_URL=http://localhost:5000

# Offline demo auth (mock users in localStorage). Keep false when backend is on.
VITE_MOCK_AUTH=false

# Leaflet / xarita uchun default markaz (Toshkent)
VITE_MAP_DEFAULT_LAT=41.2995
VITE_MAP_DEFAULT_LNG=69.2401

# Firebase Cloud Messaging (push notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
